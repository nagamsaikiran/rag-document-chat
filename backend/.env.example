# Copy to .env and fill in. Never commit your real .env.

# Which providers to use. Swap these to change backends without touching code.
# Options: openai | gemini
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini

# Google Gemini (FREE tier) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# OpenAI (only needed if LLM_PROVIDER/EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Retrieval / chunking knobs (tradeoffs documented in README)
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=4
# Cosine distance above which a chunk is considered irrelevant (drives the
# "I don't know" guardrail). 0 = identical, 2 = opposite. Tune with the eval set.
RELEVANCE_DISTANCE_THRESHOLD=0.55

# Where Chroma persists its index
CHROMA_DIR=./.chroma
